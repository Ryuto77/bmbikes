DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# Include every deployed frontend origin that should call this API.
# FRONTEND_BASE_URL is automatically added too, but keep both apex/www here if both are used.
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Supabase uses PostgreSQL. Use either DATABASE_URL or the DB_* fields below.
DB_ENGINE=postgresql
# Direct Supabase connection:
# DATABASE_URL=postgresql://postgres:replace-with-supabase-db-password@db.ahylerycccltyzwmucol.supabase.co:5432/postgres
#
# If your hosting provider only supports IPv4, use Supabase Session Pooler details instead.
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=replace-with-supabase-db-password
DB_HOST=db.ahylerycccltyzwmucol.supabase.co
DB_PORT=5432
DB_SSLMODE=require
# Set True if you use a Supabase pooler connection.
DB_DISABLE_SERVER_SIDE_CURSORS=False

DJANGO_STATIC_ROOT=/var/www/bestmotors/staticfiles
DJANGO_MEDIA_ROOT=/var/www/bestmotors/media
DJANGO_MEDIA_URL=/media/

# Optional: Supabase Storage for uploaded media instead of local/server disk.
# Create a public bucket first, then enable S3 access keys in Supabase Storage settings.
SUPABASE_STORAGE_ENABLED=False
SUPABASE_STORAGE_BUCKET=media
SUPABASE_STORAGE_REGION=ap-south-1
SUPABASE_STORAGE_S3_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_PUBLIC_URL=https://your-project-ref.supabase.co/storage/v1/object/public/media
SUPABASE_STORAGE_ACCESS_KEY_ID=replace-with-supabase-storage-access-key
SUPABASE_STORAGE_SECRET_ACCESS_KEY=replace-with-supabase-storage-secret-key

FRONTEND_BASE_URL=https://yourdomain.com
DEFAULT_FROM_EMAIL=Best Motors <no-reply@yourdomain.com>
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-smtp-username
EMAIL_HOST_PASSWORD=replace-with-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=15
PASSWORD_RESET_TIMEOUT=3600

DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SAMESITE=None
DJANGO_CSRF_COOKIE_SAMESITE=None
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Optional when your app runs behind a proxy/load balancer such as Render.
DJANGO_SECURE_PROXY_SSL_HEADER=True
